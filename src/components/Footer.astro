---
import LogoDark from "../assets/logoDark.svg"
import {
  FacebookLink,
  InstagramLink,
  YouTubeLink,
} from "../utils/commonConstants"
import type { LinkListItemType } from "../utils/commonTypes"
import FooterList from "./FooterList.astro"

import {
  getLangFromUrl,
  useTranslatedPath,
  useTranslations,
} from "../i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)

const siteLinkList: LinkListItemType[] = [
  { text: t("Admission"), href: translatePath("/admission") },
  { text: t("Curriculum"), href: translatePath("/curriculum") },
  { text: t("Blogs"), href: translatePath("/blogs") },
  { text: t("About"), href: translatePath("/about") },
  { text: t("JoinUs"), href: translatePath("/career") },
]
const socialLinkList: LinkListItemType[] = [
  { text: t("YouTube"), href: YouTubeLink },
  { text: t("Instagram"), href: InstagramLink },
  { text: t("Facebook"), href: FacebookLink },
]
---

<div
  id="Footer"
  class="flex justify-center w-full items-center py-4 md:py-5 lg:py-6 px-6 md:px-8 lg:px-12 bg-pink-300"
>
  <div
    id="Footer_Content"
    class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 w-full lg:max-w-7xl"
  >
    <LogoDark class="h-12 md:h-12 lg:h-16 w-auto col-span-2 md:col-span-1" />
    <FooterList title="Site Links" items={siteLinkList} />
    <FooterList title="Social Media" items={socialLinkList} newTab />
  </div>
</div>
