---
import { Check } from "@lucide/astro"
import type { bgColor300 } from "@utils/commonTypes"

interface Props {
  title: string
  bgColor: bgColor300
}
const { title, bgColor = "bg-white" } = Astro.props
---

<div class={`flex gap-2 md:gap-3 items-center`}>
  <div
    class={`rounded-full size-7 md:size-8 ${bgColor} flex items-center justify-center`}
  >
    <Check class="size-4 md:size-5 text-slate-800" />
  </div>
  <p class="text-xs md:text-sm text-slate-800">
    {title}
  </p>
</div>
