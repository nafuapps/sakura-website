---
import { ArrowRight } from "@lucide/astro"
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@i18n/utils"
import { AdmissionFormLink } from "@utils/commonConstants"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)
---

<a
  href={translatePath(AdmissionFormLink)}
  class="flex flex-row text-nowrap items-center justify-center bg-pink-800 hover:bg-pink-900 hover:cursor-pointer text-white gap-2 rounded-full py-3 md:py-4 px-5 md:px-6 w-full md:w-auto"
>
  <span class="font-bold text-base md:text-lg">
    {t("Home.Hero.Primary")}
  </span>
  <ArrowRight class="size-5 md:size-6" />
</a>
