---
interface Props {
  selected: boolean
  title: string
  href: string
  hideSmall?: boolean
}
const { selected, title, href, hideSmall } = Astro.props
---

<a
  href={href}
  class={`${hideSmall ? "md:hidden xl:flex" : ""} ${selected ? "text-pink-50 bg-pink-400" : "text-pink-400 hover:bg-pink-50"} rounded text-nowrap text-sm md:text-sm lg:text-base hover:cursor-pointer px-2 md:px-2.5 lg:px-3 py-1 md:py-1.5 lg:py-2`}
  >{title}</a
>
