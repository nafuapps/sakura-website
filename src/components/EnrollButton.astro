---
import {
  getLangFromUrl,
  useTranslatedPath,
  useTranslations,
} from "../i18n/utils"
import { AdmissionFormLink } from "../utils/commonConstants"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)
---

<a
  href={translatePath(AdmissionFormLink)}
  class="flex flex-row text-nowrap items-center justify-center bg-pink-400 hover:bg-pink-600 hover:cursor-pointer text-white font-bold text-xs md:text-xs lg:text-sm rounded-full py-2 md:py-2 lg:py-2.5 px-4 md:px-5 lg:px-6"
  >{t("EnrollButton")}</a
>
