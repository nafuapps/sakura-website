---
import { getLangFromUrl, useTranslatedPath } from "@i18n/utils"
import { Workflow } from "@lucide/astro"
import { AdmissionFormLink, SchoolPhoneLink } from "@utils/commonConstants"

const lang = getLangFromUrl(Astro.url)
const translatePath = useTranslatedPath(lang)

interface Props {
  title: string
  desc: string
  primaryCTA: string
  secondaryCTA: string
}
const { title, desc, primaryCTA, secondaryCTA } = Astro.props
---

<div
  class="w-full shadow-xl rounded-4xl bg-cyan-500/90 flex flex-col items-center justify-center gap-4 md:gap-6 p-6 md:p-8"
>
  <Workflow class="size-8 md:size-10 text-cyan-800" />
  <h4 class="text-cyan-800 font-bold text-2xl md:text-4xl text-center">
    {title}
  </h4>
  <p class="text-slate-800 text-xs md:text-sm text-center">{desc}</p>
  <div
    class="w-full flex items-center justify-center flex-col md:flex-row gap-4 md:gap-6"
  >
    <a
      href={translatePath(AdmissionFormLink)}
      class="w-full md:w-auto rounded-full flex items-center justify-center text-sm text-cyan-800 bg-pink-50 hover:bg-pink-100 font-semibold shadow-2xl px-6 py-3"
    >
      {primaryCTA}
    </a>
    <a
      href={SchoolPhoneLink}
      class="w-full md:w-auto rounded-full flex items-center justify-center text-sm bg-cyan-800 text-white hover:bg-cyan-900 font-semibold border border-slate-100/20 px-6 py-3"
    >
      {secondaryCTA}
    </a>
  </div>
</div>
