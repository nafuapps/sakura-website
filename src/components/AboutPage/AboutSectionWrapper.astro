---
import type { bgColor50 } from "@utils/commonTypes"

interface Props {
  id: string
  bgVariant: bgColor50
  minHScreen?: boolean
}
const { id, bgVariant, minHScreen: minHScreen = false } = Astro.props
---

<div
  id={id}
  class={`${bgVariant} ${minHScreen ? "min-h-screen" : ""} flex items-center justify-center px-6 md:px-8 py-16 md:py-24`}
>
  <slot name="about-content" />
</div>
