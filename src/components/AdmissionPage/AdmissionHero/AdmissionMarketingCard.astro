---
import { Image } from "astro:assets"

import admissionIcon1 from "@assets/admissionIcon1.png"
import admissionIcon2 from "@assets/admissionIcon2.png"
import admissionIcon3 from "@assets/admissionIcon3.png"
import { AdmissionFormLink } from "@utils/commonConstants"
import { useTranslations, getLangFromUrl } from "@i18n/utils"

const t = useTranslations(getLangFromUrl(Astro.url))
---

<div
  id="admissionHeroMarketingCard"
  class="relative w-full mb-6 md:mb-10 rounded-2xl flex flex-col p-6 md:p-10 gap-2 md:gap-3 items-start bg-linear-to-br from-pink-800/90 to-pink-600/90"
>
  <div
    class="flex items-center justify-center rounded-full bg-pink-400/70 text-tiny md:text-xs text-pink-50 px-2 md:px-3 py-1 md:py-1.5"
  >
    {t("Admission.Hero.MarketingCard.Tagline")}
  </div>
  <h2 class="text-3xl md:text-5xl font-bold text-white">
    {t("Admission.Hero.MarketingCard.Title")}
  </h2>
  <p class="text-base md:text-lg text-pink-50">
    {t("Admission.Hero.MarketingCard.Subtitle")}
  </p>
  <a
    href={AdmissionFormLink}
    class="w-full md:w-auto rounded-full flex items-center justify-center text-sm bg-white text-pink-500 hover:bg-slate-50 font-semibold px-6 py-3"
  >
    {t("Admission.Hero.MarketingCard.PrimaryCTA")}
  </a>
  <Image
    src={admissionIcon1}
    alt="Marketing Icon 1"
    class="h-8 md:h-12 w-auto absolute top-2 md:top-3 right-4 md:right-6"
  />
  <Image
    src={admissionIcon2}
    alt="Marketing Icon 2"
    class="h-10 md:h-16 w-auto absolute bottom-2 md:bottom-3 -left-1 md:-left-2"
  />
  <Image
    src={admissionIcon3}
    alt="Marketing Icon 3"
    class="h-10 md:h-16 w-auto absolute top-3 md:top-4 left-40 md:left-80"
  />
</div>
