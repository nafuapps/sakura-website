---
import type { bgColor50, bgLineColor } from "@utils/commonTypes"

interface Props {
  showColor: bgLineColor
  hide?: boolean
  hideColor?: bgColor50
}
const { showColor, hide, hideColor } = Astro.props
---

<div
  class={`flex ${hide ? hideColor : showColor} h-full w-1 md:h-1 md:w-full grow`}
>
</div>
