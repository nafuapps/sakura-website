---
import { getLangFromUrl, useTranslatedPath, useTranslations } from "@i18n/utils"
import { AdmissionFormLink } from "@utils/commonConstants"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
const translatePath = useTranslatedPath(lang)
---

<a
  href={translatePath(AdmissionFormLink)}
  class="flex flex-row text-nowrap items-center justify-center bg-pink-800 hover:bg-pink-900 hover:cursor-pointer text-pink-50 font-bold text-xs md:text-sm rounded-full py-2 md:py-2.5 px-5 md:px-6"
  >{t("EnrollButton")}</a
>
