---
interface Props {
  selected: boolean
  title: string
  href: string
}
const { selected, title, href } = Astro.props
---

<a
  href={href}
  class={`${selected ? "text-pink-700 border-b-2 border-b-pink-500 pb-1" : "text-slate-800 hover:text-pink-500"} text-nowrap text-sm hover:cursor-pointer`}
  >{title}</a
>
