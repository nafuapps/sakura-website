---
import type { LinkListItemType } from "@utils/commonTypes"
interface Props {
  title: string
  items: LinkListItemType[]
  newTab?: boolean
}
const { title, items, newTab } = Astro.props
---

<div class="flex flex-col gap-2 md:gap-3">
  <span class="text-base
  md:text-lg
  font-bold
  text-white">
    {title}
  </span>
  {
    items.map((i) => {
      return (
        <a
          href={i.href}
          target={newTab ? "_blank" : "_self"}
          class="text-sm md:text-sm text-slate-100 hover:text-pink-200 hover:cursor-pointer hover:underline text-wrap"
        >
          {i.text}
        </a>
      )
    })
  }
</div>
