---
import { Baby } from "@lucide/astro"
import CurriculumContentWrapper from "../CurriculumContentWrapper.astro"
import CurriculumSectionDescription from "../CurriculumSectionDescription.astro"
import CurriculumSectionWrapper from "../CurriculumSectionWrapper.astro"
import { useTranslations, getLangFromUrl } from "@i18n/utils"
import { AdmissionFormLink, SchoolPhoneLink } from "@utils/commonConstants"
const t = useTranslations(getLangFromUrl(Astro.url))
---

<CurriculumSectionWrapper id="CurriculumMarketing" bgVariant="bg-white">
  <CurriculumContentWrapper slot="curriculum-content">
    <div
      class="bg-pink-200 p-4 rounded-full size-12 md:size-16 flex items-center justify-center"
    >
      <Baby class="text-pink-800 size-9 md:size-10" />
    </div>
    <h2 class="text-3xl md:text-5xl font-black text-pink-800 text-center">
      {t("Curriculum.Marketing.Title")}
    </h2>
    <CurriculumSectionDescription
      description={t("Curriculum.Marketing.Description")}
    />
    <div
      class="flex w-full flex-col justify-center md:flex-row gap-4 md:gap-6 items-center"
    >
      <a
        href={AdmissionFormLink}
        class="flex items-center justify-center bg-pink-800 w-full md:w-auto rounded-full shadow-xl px-4 md:px-6 py-2 md:py-3 text-white hover:bg-pink-900 font-bold text-sm md:text-base"
      >
        {t("Curriculum.Marketing.Primary")}
      </a>
      <a
        href={SchoolPhoneLink}
        class="flex items-center justify-center bg-white w-full md:w-auto border border-pink-800 rounded-full px-4 md:px-6 py-2 md:py-3 text-pink-800 hover:bg-slate-50 font-bold text-sm md:text-base"
      >
        {t("Curriculum.Marketing.Secondary")}
      </a>
    </div>
  </CurriculumContentWrapper>
</CurriculumSectionWrapper>
