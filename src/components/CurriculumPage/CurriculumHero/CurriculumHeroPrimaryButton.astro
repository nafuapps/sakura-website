---
import { Download } from "@lucide/astro"
import { getLangFromUrl, useTranslations } from "@i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<a
  href={"/files/sakuraCurriculumBrochure.pdf"}
  download
  class="flex flex-row text-nowrap shadow items-center justify-center bg-pink-800 hover:bg-pink-900 hover:cursor-pointer text-white gap-2 rounded-full py-3 md:py-4 px-5 md:px-6 w-full md:w-auto"
>
  <span class="font-bold text-base md:text-lg">
    {t("Curriculum.Hero.Primary")}
  </span>
  <Download class="size-5 md:size-6" />
</a>
