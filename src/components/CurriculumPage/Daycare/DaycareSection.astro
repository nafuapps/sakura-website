---
import { Image } from "astro:assets"
import daycare from "@assets/daycare.png"
import CurriculumContentWrapper from "../CurriculumContentWrapper.astro"
import CurriculumSectionWrapper from "../CurriculumSectionWrapper.astro"
import { useTranslations, getLangFromUrl } from "@i18n/utils"
import DaycareItem from "./DaycareItem.astro"
import { SchoolPhoneLink } from "@utils/commonConstants"
const t = useTranslations(getLangFromUrl(Astro.url))
---

<CurriculumSectionWrapper id="daycare" bgVariant="bg-cyan-50">
  <CurriculumContentWrapper
    slot="curriculum-content"
    largeDirection="md:flex-row"
  >
    <!-- Change the title and description to match the daycare section content -->
    <div class="flex w-full md:w-1/2 relative mb-2 md:mb-0">
      <div class="w-5/6 -rotate-4 bg-cyan-100/70 rounded-2xl aspect-square">
      </div>
      <Image
        src={daycare}
        alt="Sakura Preschool Kokrajhar Daycare Image"
        class="object-cover absolute rounded-2xl shadow aspect-square w-4/5"
      />
    </div>
    <div class="flex w-full md:w-1/2 flex-col gap-6 md:gap-8 items-start">
      <div
        class={`flex w-auto items-center justify-center text-tiny md:text-xs text-cyan-50 font-semibold gap-1 md:gap-1.5 px-2 md:px-3 py-1 md:py-1.5 rounded-lg bg-cyan-800`}
      >
        <p>
          {t("Curriculum.Daycare.Tag")}
        </p>
      </div>
      <h3 class="text-2xl md:text-4xl font-bold text-cyan-800 text-start">
        {t("Curriculum.Daycare.Title")}
      </h3>
      <p class="text-sm md:text-base text-slate-600">
        {t("Curriculum.Daycare.Description")}
      </p>
      <div class="flex flex-col gap-3 md:gap-4">
        <DaycareItem title={t("Curriculum.Daycare.Item1")} />
        <DaycareItem title={t("Curriculum.Daycare.Item2")} />
        <DaycareItem title={t("Curriculum.Daycare.Item3")} />
        <DaycareItem title={t("Curriculum.Daycare.Item4")} />
      </div>
      <a
        href={SchoolPhoneLink}
        class="flex items-center justify-center bg-cyan-800 w-full md:w-auto rounded-full px-4 md:px-6 py-3 text-white shadow hover:bg-cyan-900 font-bold text-sm md:text-base"
      >
        {t("Curriculum.Daycare.CTA")}
      </a>
    </div>
  </CurriculumContentWrapper>
</CurriculumSectionWrapper>
