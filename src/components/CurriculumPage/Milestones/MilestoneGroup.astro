---
import { LucideChevronDown, type AstroComponent } from "@lucide/astro"
import type { bgColor200, textColor800 } from "@utils/commonTypes"

interface Props {
  id: string
  icon: AstroComponent
  title: string
  subtitle: string
  desc: string
  bgColor: bgColor200
  textColor: textColor800
  open?: boolean
}
const {
  id,
  icon: Icon,
  title,
  subtitle,
  desc,
  bgColor,
  textColor,
  open = false,
} = Astro.props
---

<details
  id={id}
  open={open}
  class="group shadow w-full bg-white rounded-2xl p-4 md:p-8 flex flex-col gap-3 md:gap-4"
>
  <summary class="flex flex-row justify-between gap-2 md:gap-3 items-center">
    <div class="flex flex-row gap-2 md:gap-3 items-center">
      <div
        class={`${bgColor} rounded-lg size-12 md:size-16 flex items-center justify-center`}
      >
        <Icon class={`${textColor} size-8 md:size-9`} />
      </div>
      <div class="flex flex-col gap-1 md:gap-1.5">
        <h4 class={`${textColor} text-base md:text-lg font-bold`}>{title}</h4>
        <p class={`${textColor} text-tiny md:text-xs font-semibold`}>
          {subtitle}
        </p>
      </div>
    </div>
    <LucideChevronDown
      class={`transition-transform duration-300 group-open:rotate-180 ${textColor}`}
    />
  </summary>
  <p class="text-slate-600 text-xs md:text-sm pb-3 md:pb-4">
    {desc}
  </p>
  <div
    class="pt-3 md:pt-4 grid grid-cols-1 md:grid-cols-2 gap-2 md:gap-3 w-full"
  >
    <slot />
  </div>
</details>
