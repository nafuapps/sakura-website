        icon={Sprout}
        title={t("Curriculum.Milestones.Nursery.Title")}
        subtitle={t("Curriculum.Milestones.Nursery.Subtitle")}
        desc={t("Curriculum.Milestones.Nursery.Description")}
        bgColor="bg-lime-200"
        textColor="text-lime-800"
