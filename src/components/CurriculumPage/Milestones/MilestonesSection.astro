          <MilestoneSkillItem
            title={t("Curriculum.Milestones.Nursery.Quarter1.Item3")}
            skill="creative"
          />
          <MilestoneSkillItem
            title={t("Curriculum.Milestones.Nursery.Quarter1.Item4")}
            skill="cognitive"
          />
        </MilestoneQuarter>
        <MilestoneQuarter
          index={2}
