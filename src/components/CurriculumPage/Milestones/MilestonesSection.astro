          />
          <MilestoneSkillItem
            title={t("Curriculum.Milestones.Kindergarten.Quarter1.Item3")}
            skill="social"
          />
          <MilestoneSkillItem
            title={t("Curriculum.Milestones.Kindergarten.Quarter1.Item4")}
            skill="cognitive"
          />
        </MilestoneQuarter>
        <MilestoneQuarter
          index={2}
