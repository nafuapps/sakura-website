            title={t("Curriculum.Milestones.Kindergarten.Quarter2.Item3")}
            skill="cognitive"
          />
          <MilestoneSkillItem
            title={t("Curriculum.Milestones.Kindergarten.Quarter2.Item4")}
            skill="social"
