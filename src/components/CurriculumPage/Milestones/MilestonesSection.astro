        icon={Shrub}
        title={t("Curriculum.Milestones.Kindergarten.Title")}
        subtitle={t("Curriculum.Milestones.Kindergarten.Subtitle")}
        desc={t("Curriculum.Milestones.Kindergarten.Description")}
        bgColor="bg-yellow-200"
        textColor="text-yellow-800"
      >
        <MilestoneQuarter
          index={1}
          bgColor="bg-yellow-200"
          textColor="text-yellow-800"
          title={t("Curriculum.Milestones.Quarter1.Title")}
          subtitle={t("Curriculum.Milestones.Kindergarten.Quarter1.Subtitle")}
