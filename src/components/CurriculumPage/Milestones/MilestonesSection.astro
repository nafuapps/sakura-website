          subtitle={t("Curriculum.Milestones.Nursery.Quarter2.Subtitle")}
        >
          <MilestoneSkillItem
            title={t("Curriculum.Milestones.Nursery.Quarter2.Item1")}
            skill="creative"
          />
          <MilestoneSkillItem
            title={t("Curriculum.Milestones.Nursery.Quarter2.Item2")}
            skill="language"
          />
          <MilestoneSkillItem
            title={t("Curriculum.Milestones.Nursery.Quarter2.Item3")}
            skill="nature"
          />
          <MilestoneSkillItem
            title={t("Curriculum.Milestones.Nursery.Quarter2.Item4")}
            skill="language"
          />
        </MilestoneQuarter>
        <MilestoneQuarter
          index={3}
          bgColor="bg-lime-200"
          textColor="text-lime-800"
