---
import type { AstroComponent } from "@lucide/astro"
import type { bgColor800 } from "@utils/commonTypes"
interface Props {
  icon: AstroComponent
  bgVariant: bgColor800
}
const { icon: Icon, bgVariant } = Astro.props
---

<div class="flex flex-col items-center px-4 md:px-6 w-1/5 md:w-1/7">
  <div class={`flex bg-pink-200 w-1 h-auto grow`}></div>
  <div
    class={`${bgVariant} border-3 md:border-4 border-white shadow flex items-center justify-center rounded-full size-10 md:size-12 shrink-0`}
  >
    <Icon class={`size-5 text-white`} />
  </div>
  <div class={`flex bg-pink-200 w-1 h-auto grow`}></div>
</div>
