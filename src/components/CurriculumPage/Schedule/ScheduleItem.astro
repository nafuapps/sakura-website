---
import type { sevenBorderColor, sevenTextColor } from "@utils/commonTypes"

interface Props {
  time: string
  title: string
  subtitle: string
  textColor: sevenTextColor
  borderColor: sevenBorderColor
  side: "left" | "right"
}
const {
  time,
  title,
  subtitle,
  textColor,
  borderColor,
  side = "right",
} = Astro.props
---

<div
  class={`rounded-2xl shadow w-4/5 md:w-3/7 my-3 md:my-2 bg-white p-4 md:p-5 flex flex-col items-start gap-1 md:gap-1.5 ${borderColor} ${side == "left" ? "md:items-end md:text-end md:border-r-0 md:border-l-4" : "md:border-r-4"}`}
>
  <h6 class={`text-sm md:text-base font-semibold ${textColor}`}>
    {time}
  </h6>
  <h6 class="text-sm md:text-base font-semibold text-slate-800">
    {title}
  </h6>
  <p class="text-tiny md:text-xs text-slate-600">
    {subtitle}
  </p>
</div>
