---
import { Image } from "astro:assets"
import Layout from "../layouts/Layout.astro"
import HeroPrimaryButton from "../components/HeroPrimaryButton.astro"
import HeroSecondaryButton from "../components/HeroSecondaryButton.astro"
import { getLangFromUrl, useTranslations } from "../i18n/utils"
import coverImage from "../assets/coverImage.png"
import aboutImage from "../assets/aboutImage.png"
import program1 from "../assets/program1.jpg"
import program2 from "../assets/program2.jpg"
import program3 from "../assets/program3.jpg"
import AboutPoint from "../components/AboutPoint.astro"
import {
  Blocks,
  BookOpenText,
  Cctv,
  Fence,
  GraduationCap,
  Medal,
  MessageCirclePlus,
  ShieldCheck,
  Star,
  Stethoscope,
  University,
  UserRoundKey,
} from "@lucide/astro"
import Metric from "../components/Metric.astro"
import ProgramItem from "../components/ProgramItem.astro"
import WhyPoint from "../components/WhyPoint.astro"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<Layout title="Sakura Preschool - Home" description="" currentTab="home">
  <div
    id="hero"
    class="bg-pink-50 border-b-2 border-b-pink-400 border-dashed h-screen flex items-center justify-center px-6 md:px-8 lg:px-12 py-18 md:py-24 lg:py-36"
  >
    <div
      id="hero-content"
      class="w-full lg:max-w-7xl h-full flex flex-col lg:flex-row gap-10 md:gap-6 lg:gap-8 items-center justify-center"
    >
      <div
        id="hero-left"
        class="flex flex-col gap-4 md:gap-5 lg:gap-6 w-full lg:w-1/2 items-center text-center lg:text-start lg:items-start"
      >
        <h1 class="text-2xl md:text-3xl font-bold text-pink-400">
          {t("Home.Hero.Title")}
        </h1>
        <p class="text-base md:text-lg text-pink-950">
          {t("Home.Hero.Subtitle")}
        </p>
        <div class="flex flex-row gap-4 md:gap-5 lg:gap-6">
          <HeroSecondaryButton />
          <HeroPrimaryButton />
        </div>
      </div>
      <div
        id="hero-right"
        class="flex flex-col gap-4 md:gap-6 lg:gap-8 w-full lg:w-1/2 items-center lg:items-end"
      >
        <Image
          src={coverImage}
          alt="Hero Image"
          class="w-full rounded-lg h-64 md:h-72 lg:h-80 md:w-full object-cover"
        />
      </div>
    </div>
  </div>
  <div
    id="about"
    class="flex items-center justify-center px-6 md:px-8 lg:px-12 py-18 md:py-24 lg:py-36"
  >
    <div
      id="about-content"
      class="w-full lg:max-w-7xl flex flex-col gap-6 md:gap-8 lg:gap-10 items-center justify-center"
    >
      <h2 class="text-xl md:text-2xl font-bold text-pink-400 text-center">
        {t("Home.About.Title")}
      </h2>
      <p class="text-sm md:text-base text-pink-950 text-center max-w-3xl">
        {t("Home.About.Description")}
      </p>
      <div
        id="about-points"
        class="flex flex-col md:flex-row md:items-center gap-4 md:gap-5 lg:gap-6"
      >
        <div class="flex flex-col gap-3 md:gap-4 lg:gap-5 items-start">
          <AboutPoint
            title={t("Home.About.Point1.Title")}
            description={t("Home.About.Point1.Description")}
            icon={GraduationCap}
          />
          <AboutPoint
            title={t("Home.About.Point2.Title")}
            description={t("Home.About.Point2.Description")}
            icon={BookOpenText}
          />
        </div>
        <Image
          src={aboutImage}
          alt="About Image"
          class="rounded-lg w-3/4 sm:w-2/3 md:w-full self-center object-cover"
        />
        <div class="flex flex-col gap-3 md:gap-4 lg:gap-5 md:items-end">
          <AboutPoint
            title={t("Home.About.Point3.Title")}
            description={t("Home.About.Point3.Description")}
            icon={University}
          />
          <AboutPoint
            title={t("Home.About.Point4.Title")}
            description={t("Home.About.Point4.Description")}
            icon={MessageCirclePlus}
          />
        </div>
      </div>
    </div>
  </div>
  <div
    id="metrics"
    class="w-full h-48 md:h-64 flex items-center justify-center p-6 md:p-8 lg:p-12 lg:h-80 bg-cover bg-center bg-[url('../assets/numbersBG.png')]"
  >
    <div
      id="metrics-content"
      class="w-full lg:max-w-7xl flex flex-row items-center text-center justify-around gap-2 md:gap-3 lg:gap-4 h-full"
    >
      <Metric title="15+" desc="Years of Experience" icon={Star} />
      <Metric title="100%" desc="Safe environment" icon={ShieldCheck} />
      <Metric title="10:1" desc="Student-Teacher Ratio" icon={Blocks} />
    </div>
  </div>
  <div
    id="why"
    class="flex items-center justify-center px-6 md:px-8 lg:px-12 py-18 md:py-24 lg:py-36"
  >
    <div
      id="why-content"
      class="w-full lg:max-w-7xl flex flex-col gap-6 md:gap-8 lg:gap-10 items-center justify-center py-6 md:py-8 lg:py-12"
    >
      <h2 class="text-xl md:text-2xl font-bold text-pink-400 text-center">
        {t("Home.Why.Title")}
      </h2>
      <p class="text-sm md:text-base text-pink-950 text-center">
        {t("Home.Why.Description")}
      </p>
      <div
        id="why-points"
        class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6 lg:gap-8 w-full lg:w-2/3"
      >
        <WhyPoint title={t("Home.Why.Point1.Title")} icon={UserRoundKey} />
        <WhyPoint title={t("Home.Why.Point2.Title")} icon={Cctv} />
        <WhyPoint title={t("Home.Why.Point3.Title")} icon={Stethoscope} />
        <WhyPoint title={t("Home.Why.Point4.Title")} icon={ShieldCheck} />
        <WhyPoint title={t("Home.Why.Point5.Title")} icon={Fence} />
        <WhyPoint title={t("Home.Why.Point6.Title")} icon={Medal} />
      </div>
    </div>
  </div>
  <div
    id="programs"
    class="flex items-center justify-center px-6 md:px-8 lg:px-12 py-18 md:py-24 lg:py-36 bg-pink-50"
  >
    <div
      id="programs-content"
      class="w-full lg:max-w-7xl flex flex-col gap-6 md:gap-8 lg:gap-10 items-center justify-center"
    >
      <h2 class="text-xl md:text-2xl font-bold text-pink-400 text-center">
        {t("Home.Programs.Title")}
      </h2>
      <p class="text-sm md:text-base text-pink-950 text-center max-w-3xl">
        {t("Home.Programs.Description")}
      </p>
      <div
        id="programs-list"
        class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-7 lg:gap-8"
      >
        <ProgramItem
          imageSrc={program1}
          title={t("Home.Programs.Program1.Title")}
          subtitle={t("Home.Programs.Program1.Subtitle")}
          description={t("Home.Programs.Program1.Description")}
          href="/curriculum#explorers"
          cta={t("Home.ProgramItem.LearnMore")}
        />
        <ProgramItem
          imageSrc={program2}
          title={t("Home.Programs.Program2.Title")}
          subtitle={t("Home.Programs.Program2.Subtitle")}
          description={t("Home.Programs.Program2.Description")}
          href="/curriculum#discoverers"
          cta={t("Home.ProgramItem.LearnMore")}
        />
        <ProgramItem
          imageSrc={program3}
          title={t("Home.Programs.Program3.Title")}
          subtitle={t("Home.Programs.Program3.Subtitle")}
          description={t("Home.Programs.Program3.Description")}
          href="/curriculum#creators"
          cta={t("Home.ProgramItem.LearnMore")}
        />
      </div>
    </div>
  </div>
</Layout>
