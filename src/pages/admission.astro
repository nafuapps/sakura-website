---
import { Image } from "astro:assets"
import Layout from "../layouts/Layout.astro"
import coverImage from "../assets/admissionCover.jpg"
import formImage from "../assets/admissionForm.png"
import web3Icon from "../assets/web3Icon.png"
import { getLangFromUrl, useTranslations } from "../i18n/utils"
import { web3FormAccessKey } from "../utils/commonConstants"
import FAQItem from "../components/FAQItem.astro"
import { MapPinHouse } from "@lucide/astro"

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)
---

<Layout
  title="Sakura Preschool - Admission"
  description="Admission page for Sakura Preschool - Find all admission related details here"
  currentTab="admission"
>
  <div
    id="hero"
    class="bg-blue-50 border-b-2 border-b-blue-400 border-dashed h-screen flex items-center justify-center px-6 md:px-8 md:px-12 py-18 md:py-24 md:py-36"
  >
    <div
      id="hero-content"
      class="w-full md:max-w-7xl h-full flex flex-col md:flex-row gap-10 md:gap-6 md:gap-8 items-center justify-center"
    >
      <div
        id="hero-left"
        class="flex flex-col gap-4 md:gap-6 md:gap-8 w-full md:w-1/2 items-center md:items-start"
      >
        <Image
          src={coverImage}
          alt="Hero Image"
          class="w-full rounded-lg h-64 md:h-72 md:h-80 md:w-full object-cover"
        />
      </div>
      <div
        id="hero-right"
        class="flex flex-col gap-4 md:gap-5 md:gap-6 w-full md:w-1/2 items-center text-center md:text-end md:items-end"
      >
        <div
          class="flex items-center gap-0.5 md:gap-1 text-center rounded-full text-tiny md:text-xs px-1 md:px-2 py-0.5 md:py-1 bg-blue-400 text-white"
        >
          {t("Admission.Hero.Tagline")}
          <MapPinHouse class="size-3 md:size-4 text-white" />
        </div>
        <h1 class="text-2xl md:text-3xl font-bold text-blue-400">
          {t("Admission.Hero.Title")}
        </h1>
        <p class="text-base md:text-lg text-blue-950">
          {t("Admission.Hero.Subtitle")}
        </p>
      </div>
    </div>
  </div>
  <div
    id="process"
    class="flex items-center justify-center px-6 md:px-8 md:px-12 py-18 md:py-24 md:py-36"
  >
    <div
      id="process-content"
      class="w-full md:max-w-7xl flex flex-col gap-6 md:gap-8 md:gap-10 items-center justify-center"
    >
      <h2 class="text-xl md:text-2xl font-bold text-pink-400 text-center">
        {t("Admission.Process.Title")}
      </h2>
      <p class="text-sm md:text-base text-pink-950 text-center max-w-3xl">
        {t("Admission.Process.Description")}
      </p>
      <div
        id="process-steps"
        class="flex flex-col gap-4 justify-center items-center"
      >
        <div
          id="step1"
          class="flex flex-col gap-2 md:gap-2.5 md:gap-3 border border-pink-400 py-2 px-4 rounded-md w-full md:w-2/3"
        >
          <h5 class="text-base md:text-lg font-semibold text-pink-400">
            {t("Admission.Process.Step1.Title")}
          </h5>
          <p class="text-xs md:text-sm text-pink-950">
            {t("Admission.Process.Step1.Description")}
          </p>
        </div>
        <div
          id="step2"
          class="flex flex-col gap-2 md:gap-2.5 md:gap-3 border border-pink-400 py-2 px-4 rounded-md w-full md:w-2/3"
        >
          <h5 class="text-base md:text-lg font-semibold text-pink-400">
            {t("Admission.Process.Step2.Title")}
          </h5>
          <p class="text-xs md:text-sm text-pink-950">
            {t("Admission.Process.Step2.Description")}
          </p>
        </div>
        <div
          id="step3"
          class="flex flex-col gap-2 md:gap-2.5 md:gap-3 border border-pink-400 py-2 px-4 rounded-md w-full md:w-2/3"
        >
          <h5 class="text-base md:text-lg font-semibold text-pink-400">
            {t("Admission.Process.Step3.Title")}
          </h5>
          <p class="text-xs md:text-sm text-pink-950">
            {t("Admission.Process.Step3.Description")}
          </p>
        </div>
        <div
          id="documents"
          class="bg-pink-50 rounded-lg w-full md:w-2/3 py-2 px-4"
        >
          <h5 class="text-base md:text-lg font-semibold text-pink-400">
            {t("Admission.Process.Documents.Title")}
          </h5>
          <ul
            class="list-disc list-inside flex flex-col mt-1 md:mt-2 gap-1.5 md:gap-2"
          >
            <li class="text-xs md:text-sm text-pink-950">
              {t("Admission.Process.Documents.List1")}
            </li>
            <li class="text-xs md:text-sm text-pink-950">
              {t("Admission.Process.Documents.List2")}
            </li>
            <li class="text-xs md:text-sm text-pink-950">
              {t("Admission.Process.Documents.List3")}
            </li>
            <li class="text-xs md:text-sm text-pink-950">
              {t("Admission.Process.Documents.List4")}
            </li>
            <li class="text-xs md:text-sm text-pink-950">
              {t("Admission.Process.Documents.List5")}
            </li>
          </ul>
        </div>
      </div>
      <div
        id="enrollment-annoucement"
        class="flex flex-col border-2 border-blue-400 items-center bg-blue-50 rounded-lg w-full md:w-2/3 py-2 md:py-2.5 md:py-3 px-4 md:px-4.5 md:px-5 gap-2 md:gap-2.5 md:gap-3"
      >
        <h3 class="text-lg md:text-xl font-semibold text-blue-400 text-center">
          {t("Admission.Process.Enrollment.Title")}
        </h3>
        <a
          href="/files/enrollmentForm.pdf"
          download
          class="bg-blue-400 cursor-pointer rounded-lg py-3 md:py-3.5 md:py-4 px-4 md:px-4.5 md:px-5 text-sm md:text-base text-white"
        >
          {t("Admission.Process.Enrollment.DownloadCTA")}
        </a>
      </div>
    </div>
  </div>
  <div
    id="form"
    class="flex items-center justify-center px-6 md:px-8 md:px-12 py-18 md:py-24 md:py-36 bg-pink-50"
  >
    <div
      id="form-content"
      class="w-full md:max-w-7xl flex flex-col md:flex-row gap-6 md:gap-8 md:gap-10"
    >
      <div id="form-left" class="hidden md:flex">
        <Image
          src={formImage}
          alt="Form Image"
          class="w-full rounded-lg object-cover"
        />
      </div>
      <form
        id="form-right"
        class="flex flex-col gap-4 md:gap-5 md:gap-6 w-full"
        action="https://api.web3forms.com/submit"
        method="POST"
        data-loading={t("Admission.Form.Loading")}
      >
        <input type="hidden" name="access_key" value={web3FormAccessKey} />
        <h2 class="text-xl md:text-2xl font-bold text-pink-400 text-center">
          {t("Admission.Form.Title")}
        </h2>
        <p class="text-sm md:text-base text-pink-950 text-center max-w-3xl">
          {t("Admission.Form.Description")}
        </p>
        <input
          id="parentName"
          type="text"
          required
          placeholder={t("Admission.Form.Parent")}
          class="w-full md:w-auto px-4 py-2 border focus:bg-white placeholder:text-pink-400 text-pink-950 border-pink-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent"
        />
        <input
          id="childName"
          type="text"
          required
          placeholder={t("Admission.Form.Child")}
          class="w-full md:w-auto px-4 py-2 border focus:bg-white placeholder:text-pink-400 text-pink-950 border-pink-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent"
        />
        <input
          id="age"
          type="tel"
          min="1"
          max="10"
          required
          placeholder={t("Admission.Form.Age")}
          class="w-full md:w-auto px-4 py-2 border focus:bg-white placeholder:text-pink-400 text-pink-950 border-pink-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent"
        />
        <input
          id="phone"
          type="tel"
          minlength="10"
          maxlength="10"
          required
          placeholder={t("Admission.Form.Phone")}
          class="w-full md:w-auto px-4 py-2 border focus:bg-white placeholder:text-pink-400 text-pink-950 border-pink-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent"
        />
        <input
          id="email"
          type="email"
          placeholder={t("Admission.Form.Email")}
          class="w-full md:w-auto px-4 py-2 border focus:bg-white placeholder:text-pink-400 text-pink-950 border-pink-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent"
        />
        <textarea
          id="message"
          rows="5"
          placeholder={t("Admission.Form.Message")}
          class="w-full col-span-2 md:w-auto px-4 py-2 border focus:bg-white placeholder:text-pink-400 text-pink-950 border-pink-300 rounded-md focus:outline-none focus:ring-2 focus:ring-pink-400 focus:border-transparent"
        ></textarea>
        <button
          id="submit"
          type="submit"
          class="px-6 py-2 bg-pink-400 text-white rounded-md hover:bg-pink-500 focus:outline-none focus:ring-2 focus:ring-pink-400 focus:ring-offset-2"
        >
          {t("Admission.Form.Submit")}
        </button>
        <div
          id="form-secure"
          class="flex flex-row items-center justify-center gap-1 md:gap-1.5 rounded-full bg-blue-100 px-2 md:px-3 py-1 md:py-1.5"
        >
          <Image
            src={web3Icon}
            alt="Web3 Icon"
            class="size-4 md:size-5 rounded-full object-cover"
          />
          <p class="text-tiny md:text-xs text-blue-950">
            {t("Admission.Form.Note")}
          </p>
        </div>
      </form>
    </div>
  </div>
  <div
    id="faq"
    class="flex items-center justify-center px-6 md:px-8 md:px-12 py-18 md:py-24 md:py-36"
  >
    <div
      id="faq-content"
      class="w-full md:max-w-7xl flex flex-col gap-6 md:gap-8 md:gap-10 items-center justify-center"
    >
      <h2 class="text-xl md:text-2xl font-bold text-pink-400 text-center">
        {t("Admission.FAQ.Title")}
      </h2>
      <p class="text-sm md:text-base text-pink-950 text-center max-w-3xl">
        {t("Admission.FAQ.Description")}
      </p>
      <FAQItem
        question={t("Admission.FAQ.Question1")}
        answer={t("Admission.FAQ.Answer1")}
      />
      <FAQItem
        question={t("Admission.FAQ.Question2")}
        answer={t("Admission.FAQ.Answer2")}
      />
      <FAQItem
        question={t("Admission.FAQ.Question3")}
        answer={t("Admission.FAQ.Answer3")}
      />
      <FAQItem
        question={t("Admission.FAQ.Question4")}
        answer={t("Admission.FAQ.Answer4")}
      />
      <FAQItem
        question={t("Admission.FAQ.Question5")}
        answer={t("Admission.FAQ.Answer5")}
      />
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById("form-right") as HTMLFormElement
  const submitBtn = form?.querySelector(
    'button[type="submit"]',
  ) as HTMLButtonElement

  if (form && submitBtn) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault()

      const loading = form.dataset.loading
      const formData = new FormData(form)
      formData.append("parent_name", form.parentName.value)
      formData.append("child_name", form.childName.value)
      formData.append("age", form.age.value)
      formData.append("phone", form.phone.value)
      formData.append("email", form.email.value)
      formData.append("message", form.message.value)

      // Create a custom subject
      const subject = `New admission enquiry from ${form.parentName.value} ${form.phone.value}`
      // Append the custom subject to the form data
      formData.append("subject", subject)

      const originalText = submitBtn?.textContent

      submitBtn.textContent = loading ?? "Submitting..."
      submitBtn.disabled = true

      try {
        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          body: formData,
        })

        const data = await response.json()

        if (response.ok) {
          alert("Success! Your message has been sent.")
          form.reset()
        } else {
          alert("Error: " + data.message)
        }
      } catch (error) {
        alert("Something went wrong. Please try again.")
      } finally {
        submitBtn.textContent = originalText
        submitBtn.disabled = false
      }
    })
  }
</script>
